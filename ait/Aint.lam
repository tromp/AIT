let
  -- binary CL interpreter with single point basis {A}
  -- intA cont bits = cont parsed unparsed_bits
  I = \x.x;
  A = \x\y\z.x z (y (\t.z));
  CL = \cont\list.list(\bit.bit(cont A)(CL(\x.CL(\y.cont(x y)))))
in CL I

